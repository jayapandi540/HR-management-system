{
  "_comment": "Gatekeeper rejection rules. Each rule category maps to detect signals, thresholds, and actions.",

  "layout_rejection_rules": {
    "multi_column_layout": {
      "detect": ["irregular_line_order", "overlapping_text_blocks", "x_axis_jump"],
      "action": "reject_section",
      "severity": "high"
    },
    "tables_and_textboxes": {
      "detect": ["grid_structure", "cell_alignment_pattern", "boxed_text"],
      "action": "ignore_content",
      "severity": "medium"
    },
    "complex_shapes": {
      "detect": ["non_text_elements", "vector_shapes", "drawing_objects"],
      "action": "ignore",
      "severity": "low"
    },
    "background_graphics": {
      "detect": ["low_contrast_text", "watermark_pattern", "overlay_noise"],
      "action": "reject",
      "severity": "high"
    },
    "headers_footers": {
      "detect": ["repeated_lines", "page_numbers", "duplicate_blocks"],
      "action": "deduplicate_or_ignore",
      "severity": "low"
    }
  },

  "visual_rejection_rules": {
    "icons_without_text": {
      "detect": ["icon_only", "no_adjacent_text"],
      "action": "reject",
      "severity": "medium"
    },
    "skill_meters": {
      "detect": ["ring", "circle", "star", "bar"],
      "condition": "no_text_context",
      "action": "reject",
      "severity": "medium"
    },
    "image_only_elements": {
      "detect": ["image_block", "logo", "badge"],
      "condition": "no_ocr_text",
      "action": "ignore",
      "severity": "low"
    }
  },

  "content_rejection_rules": {
    "generic_phrases": {
      "detect": ["hardworking", "passionate", "enthusiastic", "self-motivated",
                 "team player", "go-getter", "results-driven", "detail-oriented"],
      "condition": "no_supporting_context",
      "action": "reject",
      "severity": "low"
    },
    "keyword_stuffing": {
      "detect": ["long_keyword_list", "comma_separated_skills", "no_structure"],
      "threshold_tokens": 30,
      "action": "reject",
      "severity": "medium"
    },
    "boilerplate_text": {
      "detect": ["legal_disclaimer", "privacy_notice", "template_text",
                 "references_available", "curriculum_vitae"],
      "position": ["top", "bottom"],
      "action": "ignore",
      "severity": "low"
    }
  },

  "source_quality_rules": {
    "low_quality_ocr": {
      "detect": ["low_confidence_score", "broken_words", "random_characters"],
      "threshold": 0.6,
      "action": "reject_section",
      "severity": "high"
    },
    "scanned_resume_only": {
      "detect": ["no_text_layer", "image_only_pdf"],
      "action": "flag_for_ocr_only",
      "severity": "medium"
    },
    "non_text_layers": {
      "detect": ["background_pdf_layer", "vector_noise", "glyph_errors"],
      "action": "clean_or_reject",
      "severity": "medium"
    }
  },

  "signals": {
    "irregular_line_order":  "y_position not increasing logically",
    "x_axis_jump":           "large horizontal shifts between consecutive lines",
    "repeated_lines":        "same text appearing multiple times",
    "broken_words":          "split tokens like E X P E R",
    "random_characters":     "symbols without semantic meaning",
    "low_confidence_score":  "ocr_confidence < threshold"
  },

  "global_thresholds": {
    "ocr_min_confidence":   0.6,
    "garble_ratio_max":     0.30,
    "min_text_chars_page":  20,
    "max_keyword_density":  0.45
  }
}